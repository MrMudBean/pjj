  "version": "1.0.6",
  "private": true,
  "scripts": {
    "build": "jja cls rm dist&&rollup --config rollup.config.js&& pnpm run clean:package",
    "clean:package": "node scripts/clean-package-json.js",
    "dev": "pnpm run build && jja cls && node dist/bin.mjs -s=dev",
